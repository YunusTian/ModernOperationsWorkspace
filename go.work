// All workspace modules target the same Go toolchain. Keep this in sync with
// CI and the minimum version documented in README.md and CONTRIBUTING.md.
go 1.25.0

// MOW Monorepo workspace
// 一次开发多个 module，避免 replace 指令扩散
use (
	./apps/cli
	./apps/desktop
	./core
	./plugins/ai
	./plugins/docker
	./plugins/ssh
	./sdk
	./tests/e2e
)
